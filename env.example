# ========================================
# SharikPlus - Переменные окружения
# ========================================

# ========================================
# База данных
# ========================================

# PostgreSQL - основная база данных
DATABASE_URL="postgresql://user:password@localhost:5432/sharikplus"

# Redis - кэширование и сессии
REDIS_URL="redis://localhost:6379"

# ========================================
# JWT Аутентификация
# ========================================

# Секретный ключ для JWT токенов (обязательно измените!)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Секретный ключ для refresh токенов
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# Время жизни access токена
JWT_EXPIRES_IN="15m"

# Время жизни refresh токена
JWT_REFRESH_EXPIRES_IN="7d"

# ========================================
# Загрузка файлов
# ========================================

# Путь для загрузки файлов
UPLOAD_PATH="./uploads"

# Максимальный размер файла (5MB)
MAX_FILE_SIZE=5242880

# Разрешенные типы файлов
ALLOWED_FILE_TYPES="image/jpeg,image/png,image/webp,image/gif"

# ========================================
# Email настройки
# ========================================

# SMTP сервер
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false

# Email учетные данные
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Email отправителя
FROM_EMAIL="noreply@sharikplus.ru"
FROM_NAME="SharikPlus"

# ========================================
# Приложение
# ========================================

# Режим работы
NODE_ENV="development"

# Порт для backend API
PORT=3001

# URL фронтенда (для CORS)
FRONTEND_URL="http://localhost:3002"

# URL backend API
BACKEND_URL="http://localhost:3001"

# ========================================
# Безопасность
# ========================================

# Соль для хэширования паролей
BCRYPT_SALT_ROUNDS=12

# CORS настройки
CORS_ORIGIN="http://localhost:3002"

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_LIMIT=100

# ========================================
# Логирование
# ========================================

# Уровень логирования
LOG_LEVEL="info"

# Путь к файлам логов
LOG_PATH="./logs"

# ========================================
# Swagger документация
# ========================================

# Включить Swagger документацию
SWAGGER_ENABLED=true

# Путь к Swagger UI
SWAGGER_PATH="api/docs"

# ========================================
# Мониторинг
# ========================================

# Включить health checks
HEALTH_CHECK_ENABLED=true

# Путь к health check
HEALTH_CHECK_PATH="/health"

# ========================================
# Разработка
# ========================================

# Включить автоматическую перезагрузку
AUTO_RELOAD=true

# Включить отладку
DEBUG=true

# ========================================
# Продакшн настройки
# ========================================

# В продакшне измените эти значения:

# DATABASE_URL="postgresql://prod_user:prod_password@prod_host:5432/sharikplus_prod"
# REDIS_URL="redis://prod_redis_host:6379"
# JWT_SECRET="your-production-jwt-secret-key"
# JWT_REFRESH_SECRET="your-production-refresh-secret-key"
# NODE_ENV="production"
# SMTP_USER="prod-email@sharikplus.ru"
# SMTP_PASS="prod-app-password"
# FRONTEND_URL="https://sharikplus.ru"
# BACKEND_URL="https://api.sharikplus.ru"
# CORS_ORIGIN="https://sharikplus.ru"
# LOG_LEVEL="error"
# DEBUG=false
# AUTO_RELOAD=false

# ========================================
# Дополнительные настройки
# ========================================

# Время ожидания для запросов к БД (мс)
DATABASE_TIMEOUT=5000

# Размер пула соединений с БД
DATABASE_POOL_SIZE=10

# Время жизни соединения с Redis (мс)
REDIS_TTL=3600000

# Максимальное количество попыток подключения
MAX_RETRY_ATTEMPTS=3

# Время между попытками подключения (мс)
RETRY_DELAY=1000

# ========================================
# Интеграции (опционально)
# ========================================

# Google Analytics
GOOGLE_ANALYTICS_ID=""

# Яндекс.Метрика
YANDEX_METRIKA_ID=""

# Telegram Bot Token (для уведомлений)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ========================================
# Платежные системы (опционально)
# ========================================

# ЮKassa
YUKASSA_SHOP_ID=""
YUKASSA_SECRET_KEY=""

# Сбербанк
SBERBANK_MERCHANT_ID=""
SBERBANK_SECRET_KEY=""

# ========================================
# Доставка (опционально)
# ========================================

# СДЭК
CDEK_CLIENT_ID=""
CDEK_CLIENT_SECRET=""

# Почта России
RUSSIAN_POST_API_KEY=""

# ========================================
# Примечания
# ========================================

# 1. НИКОГДА не коммитьте реальные значения в Git
# 2. Используйте .env.local для локальной разработки
# 3. В продакшне используйте переменные окружения сервера
# 4. Регулярно меняйте секретные ключи
# 5. Используйте сильные пароли для всех сервисов
